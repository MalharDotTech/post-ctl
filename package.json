{
  "name": "postctl",
  "version": "0.1.0",
  "description": "The missing CLI for social posting. YouTube, Instagram, Facebook, X, LinkedIn. Built for humans and AI agents.",
  "type": "module",
  "bin": {
    "postctl": "./bin/postctl"
  },
  "files": [
    "bin/",
    "src/",
    "!src/**/*.test.ts",
    "!src/__fixtures__/"
  ],
  "keywords": [
    "social-media",
    "youtube",
    "instagram",
    "cli",
    "ai-agents",
    "kubectl",
    "posting",
    "automation"
  ],
  "author": "Malhar Ujawane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MalharDotTech/postctl"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --minify src/cli.ts --outfile postctl",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
