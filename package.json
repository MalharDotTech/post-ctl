{
  "name": "postctl",
  "version": "0.3.0",
  "description": "The missing CLI for social posting. YouTube, Instagram, Facebook, X, LinkedIn. Built for humans and AI agents.",
  "type": "module",
  "private": true,
  "//": "Source/dev manifest. The published npm package is assembled in dist/npm (scripts/npm-pack.ts) — this repo is not published directly.",
  "bin": {
    "postctl": "./bin/postctl"
  },
  "keywords": [
    "social-media",
    "youtube",
    "instagram",
    "cli",
    "ai-agents",
    "kubectl",
    "posting",
    "automation"
  ],
  "author": "Malhar Ujawane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MalharDotTech/post-ctl"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun run scripts/build.ts",
    "build:npm": "bun run scripts/npm-pack.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
